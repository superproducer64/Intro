{
  "expo": {
    "name": "Intro",
    "slug": "intro",
    "version": "1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bgpstudios.intro",
      "buildNumber": "16",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Intro needs camera access to take profile photos and for video calls with your matches.",
        "NSMicrophoneUsageDescription": "Intro needs microphone access for video calls with your matches.",
        "NSPhotoLibraryUsageDescription": "Intro needs photo library access to set your profile photo.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["voip"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.bgpstudios.intro",
      "versionCode": 1
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      "expo-status-bar",
      "expo-video",
      [
        "@daily-co/config-plugin-rn-daily-js",
        {
          "enableCamera": true,
          "enableMicrophone": true,
          "enableScreenShare": false
        }
      ]
    ],
    "owner": "superproducer64",
    "extra": {
      "eas": {
        "projectId": "e6b34b98-b3f4-450a-94f8-69146b0464db"
      },
      "apiUrl": "https://intro-bgpstudioshou.replit.app"
    }
  }
}
